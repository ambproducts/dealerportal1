# AmeriDex Dealer Portal - Environment Variables

# Port (default: 3000)
PORT=3000

# Token secret for signing authentication tokens (REQUIRED in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=your-secret-key-here-change-in-production

# Data directory (default: ./data)
DATA_DIR=./data

# Master key for database backup/export API access (REQUIRED for /api/master/* endpoints)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=your-master-key-here-change-in-production

# ---------------------------------------------------------------
# FORMSPREE (email notifications - server-side)
# ---------------------------------------------------------------
# The portal uses Formspree as its ONLY outbound email channel.
# All form IDs come from your Formspree dashboard (formspree.io).
#
# FORMSPREE_REVISION_FORM_ID
#   Used by PATCH /api/quotes/:id/revision when notify=true.
#   The server POSTs directly to https://formspree.io/f/<id>
#   so the form ID never reaches the browser.
#   Create a dedicated form in Formspree ("Quote Revision Request")
#   and paste only the 8-character ID here (e.g. xpwzabcd).
#
# FORMSPREE_SUBMIT_FORM_ID  (optional, for future use)
#   If you want the server to also email on quote submission
#   instead of relying on the existing client-side Formspree call.
# ---------------------------------------------------------------
FORMSPREE_REVISION_FORM_ID=your-formspree-form-id-here
# FORMSPREE_SUBMIT_FORM_ID=your-second-form-id-here
