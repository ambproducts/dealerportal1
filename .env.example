# AmeriDex Dealer Portal - Environment Variables

# Port (default: 3000)
PORT=3000

# Token secret for signing authentication tokens (REQUIRED in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=your-secret-key-here-change-in-production

# Data directory (default: ./data)
DATA_DIR=./data

# Master key for database backup/export API access (REQUIRED for /api/master/* endpoints)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=your-master-key-here-change-in-production

# ---------------------------------------------------------------
# FORMSPREE (email notifications - server-side)
# ---------------------------------------------------------------
# The portal uses Formspree as its ONLY outbound email channel.
# All form IDs come from your Formspree dashboard (formspree.io).
# The server POSTs JSON directly to https://formspree.io/f/<id>
# so form IDs never reach the browser.
#
# Create each form in Formspree, then paste the 8-char ID below.
#
# FORMSPREE_SUBMIT_FORM_ID
#   Fires automatically on every POST /api/quotes/:id/submit.
#   AmeriDex receives: quote number, dealer code, customer info,
#   full line-item summary, total amount, and notes.
#
# FORMSPREE_REVISION_FORM_ID
#   Fires on PATCH /api/quotes/:id/revision when notify=true.
#   AmeriDex receives: quote number, dealer code, customer,
#   revision reason, line-item summary, and total.
# ---------------------------------------------------------------
FORMSPREE_SUBMIT_FORM_ID=your-submit-form-id-here
FORMSPREE_REVISION_FORM_ID=your-revision-form-id-here
